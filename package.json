{
  "name": "omega-client",
  "version": "0.1.0",
  "description": "Omega Client - The last client you will ever need. A lightweight, offline, mod-toggle-focused Minecraft launcher built for smooth PvP performance.",
  "main": "dist-electron/main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development tsc -p tsconfig.electron.json && electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win portable nsis --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage --publish never",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "playwright": "^1.56.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.omega.client",
    "productName": "Omega Client",
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bundled",
        "to": "bundled",
        "filter": [
          "*.jar"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "OmegaClient-Setup.exe"
    },
    "portable": {
      "artifactName": "OmegaClient-Portable.exe"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.games",
      "artifactName": "OmegaClient-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Game",
      "artifactName": "OmegaClient-${arch}.${ext}"
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/dsdocai-ops/Mods/releases/download/latest-build"
    }
  }
}
